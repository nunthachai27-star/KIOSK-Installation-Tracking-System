# Environment variables for KIOSK Installation Tracking System
# Copy this file to .env and fill in values as needed by later tasks.
# docker-compose maps Postgres to host port 5434 (avoids clashing with a native Postgres on 5432).
DATABASE_URL="postgresql://kiosk:kiosk@localhost:5434/kiosk?schema=public"

# Auth.js (next-auth v5) secret. Generate with: npx auth secret  (or) node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
