generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OFFICE
  FIELD
  ADMIN
  TECHNICIAN
  EXECUTIVE
  SYSTEM_ADMIN
}

enum JobStatus {
  DATA_ENTRY
  PREPARING
  QC
  READY_TO_SHIP
  INSTALLING
  HANDED_OVER
  WAIT_INVOICE
  CLOSED
  PROBLEM
  CANCELLED
}

enum SerialType {
  BMS
  KIOSK
  UPS
  MINI_PC
  SMART_CARD_READER
  PRINTER
  KEY_ID
}

enum DeliveryStatus {
  PENDING
  SCHEDULED
  SHIPPING
  ARRIVED
  DELAYED
  PROBLEM
}

enum InstallType {
  REMOTE
  ONSITE
  REMOTE_ONSITE
}

enum InstallStatus {
  PENDING
  SCHEDULED
  INSTALLING
  DONE
  FAILED
  PROBLEM
  POSTPONED
}

enum QcStatus {
  PENDING
  PASSED
  FAILED
}

enum SerialStatus {
  PENDING
  IN_PROGRESS
  DONE
  PROBLEM
}

enum IssueStatus {
  RECEIVED
  IN_PROGRESS
  WAIT_CUSTOMER_RETURN
  SENT_TO_SUPPLIER
  SHIPPING_TO_CUSTOMER
  WAIT_ONSITE
  QUOTATION
  DONE
  REJECTED
}

enum IssueType {
  CLAIM   // แจ้งเคลมอุปกรณ์ (ยึดตาม S/N)
  GENERAL // แจ้งปัญหาทั่วไป
}

enum IssueMethod {
  REMOTE
  ONSITE
}

enum IssueWarranty {
  IN_WARRANTY
  OUT_OF_WARRANTY
  NOT_COVERED
  UNKNOWN
}

enum IssueEventType {
  CREATED
  STATUS_CHANGED
  SOLUTION_UPDATED
  WARRANTY_SET
  PART_USED
  RATED
}

enum HandoverStatus {
  PENDING
  RECEIVED
  DELIVERED
}

enum InvoiceStatus {
  PENDING
  ISSUED
  SENT_TO_ACCOUNTING
}

enum ActivityType {
  DELIVERY
  REMOTE
  ONSITE
  TRAINING
  QC
  HANDOVER
  TASK
}

enum ActivityStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  DONE
  POSTPONED
  PROBLEM
}

model User {
  id            String        @id @default(cuid())
  username      String        @unique
  passwordHash  String
  name          String
  nickname      String?
  role          Role          @default(FIELD)
  avatarColor   String?
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  adminJobs     Job[]          @relation("AdminOwner")
  installerJobs Job[]          @relation("InstallerOwner")
  createdJobs   Job[]          @relation("JobCreator")
  activities    JobActivity[]
  serialRecords SerialRecord[] @relation("SerialStaff")
  qcRecords     QcRecord[]     @relation("QcStaff")
  unitQcs       UnitQc[]       @relation("UnitQcStaff")
  issues        Issue[]        @relation("IssueReporter")
  assignedIssues Issue[]       @relation("IssueAssignee")
  ownedTasks    Task[]         @relation("TaskOwner")
  loansRecorded Loan[]         @relation("LoanRecorder")
  purchases     Purchase[]     @relation("PurchaseRequester")
}

enum PurchaseStatus {
  REQUESTED  // ขอซื้อ
  APPROVED   // อนุมัติแล้ว
  ORDERED    // สั่งซื้อแล้ว
  SHIPPING   // กำลังจัดส่ง
  RECEIVED   // รับของแล้ว
  CANCELLED  // ยกเลิก
}

// งานจัดซื้อ — standalone procurement tracking (ยังไม่ผูกกับคลังสินค้า).
model Purchase {
  id            String         @id @default(cuid())
  itemName      String         // ชื่อสินค้า/อุปกรณ์ที่จัดซื้อ
  category      String?        // ประเภท/หมวด
  quantity      Int            @default(1)
  unit          String         @default("ชิ้น")
  vendor        String?        // ผู้ขาย/ร้านค้า
  price         Decimal?       // ราคา/งบประมาณ (รวม)
  status        PurchaseStatus @default(REQUESTED)
  note          String?
  neededDate    DateTime?      // วันที่ต้องการใช้
  orderedDate   DateTime?      // วันสั่งซื้อ
  receivedDate  DateTime?      // วันรับของ
  requestedBy   User?          @relation("PurchaseRequester", fields: [requestedById], references: [id])
  requestedById String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
}

// Ad-hoc work reminder not tied to a job/ORDER (ประชุม / ติดตามงาน / อบรม / อื่นๆ).
// Shows on the Monitor board across its date range.
model Task {
  id                String         @id @default(cuid())
  title             String         // รายละเอียดงาน
  kind              String         @default("อื่นๆ") // ประเภทงาน
  hospitalName      String?        // ชื่อโรงพยาบาล (ถ้ามี)
  responsibleUser   User?          @relation("TaskOwner", fields: [responsibleUserId], references: [id])
  responsibleUserId String?
  startDate         DateTime
  endDate           DateTime?
  status            ActivityStatus @default(SCHEDULED)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([startDate])
}

model Hospital {
  id           String  @id @default(cuid())
  name         String
  code         String? // รหัสสถานพยาบาล (HCODE 5 หลัก)
  province     String
  healthRegion String?
  address      String?
  latitude     Float?
  longitude    Float?
  remark       String?
  jobs         Job[]
  stockItems   StockItem[]
}

model Job {
  id                String              @id @default(cuid())
  jobCode           String              @unique
  sourceLot         String?
  hospital          Hospital            @relation(fields: [hospitalId], references: [id])
  hospitalId        String
  province          String
  productType       String
  productModel      String?
  color             String?
  quantity          Int                 @default(1)
  salesAmount       Decimal             @default(0)
  contactName       String?
  contactPhone      String?
  supplyContactName  String?
  supplyContactPhone String?
  contractNo        String?
  contractStartDate DateTime?
  contractEndDate   DateTime?
  deliveryDueDate   DateTime?
  // Planned job (no contract yet) vs signed contract. Planned jobs hide the
  // contract fields and live in a separate registry for admin follow-up.
  isPlanned         Boolean             @default(false)
  currentStatus     JobStatus           @default(DATA_ENTRY)
  adminOwner        User?               @relation("AdminOwner", fields: [adminOwnerId], references: [id])
  adminOwnerId      String?
  installerOwner    User?               @relation("InstallerOwner", fields: [installerOwnerId], references: [id])
  installerOwnerId  String?
  createdBy         User?               @relation("JobCreator", fields: [createdById], references: [id])
  createdById       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  serials           SerialNumber[]
  serialRecord      SerialRecord?
  issues            Issue[]
  qc                QcRecord?
  delivery          DeliveryRecord?
  installation      InstallationRecord?
  handover          HandoverRecord?
  invoice           InvoiceRecord?
  activities        JobActivity[]
  stockItems        StockItem[]
}

model SerialNumber {
  id         String      @id @default(cuid())
  job        Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId      String
  // Legacy enum classification (kept for existing data + the BMS asset tag).
  serialType SerialType?
  // Free-text component name (new model): which component this serial belongs to.
  label      String?
  serialNo   String
  remark     String?
  // Component serials link to their BMS unit (a serialType=BMS row = one unit).
  parent     SerialNumber?  @relation("Unit", fields: [parentId], references: [id], onDelete: Cascade)
  parentId   String?
  children   SerialNumber[] @relation("Unit")
  // Per-unit QC (only set on BMS-unit rows).
  unitQc     UnitQc?
  issues     Issue[]

  @@index([jobId])
  @@index([parentId])
}

// Hospital warranty claim / problem report — tied to a BMS unit of a job when it
// exists in this system, else standalone (imported history) via free-text hospital.
model Issue {
  id         String      @id @default(cuid())
  job        Job?        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId      String?
  serial     SerialNumber? @relation(fields: [serialId], references: [id], onDelete: SetNull)
  serialId   String?
  // Fallbacks for claims whose unit/job is not tracked here (historical import).
  hospitalName  String?  // free-text hospital when not linked to a job
  machineSerial String?  // raw S/N BMS text when not linked to a SerialNumber
  productType   String?  // product line for standalone claims (job-linked ones use job.productType)
  issueType  IssueType   @default(CLAIM)
  title      String
  solution   String?
  status     IssueStatus @default(RECEIVED)
  // Claim/warranty tracking (ยึดตาม S/N BMS ของตู้).
  warrantyState     IssueWarranty @default(UNKNOWN)
  method            IssueMethod?
  failedSerial      String?      // Serial อุปกรณ์ที่เสีย
  replacementSerial String?      // Serial อุปกรณ์ที่ส่งเคลมให้ลูกค้า
  cost              Decimal?     // ค่าใช้จ่าย (กรณีนอกประกัน/ใบเสนอราคา)
  // Satisfaction rating given by the hospital on the staff's resolution (1-5).
  rating            Int?
  ratingComment     String?
  ratedAt           DateTime?
  raterIp           String?   // IP ผู้ให้คะแนน (audit — ตรวจจับการปั่นคะแนน)
  reporter   User?       @relation("IssueReporter", fields: [reporterId], references: [id])
  reporterId String?
  // Staff who actually resolved the issue — the rating is attributed to this person.
  assignedTo   User?     @relation("IssueAssignee", fields: [assignedToId], references: [id])
  assignedToId String?
  events     IssueEvent[]
  parts      ClaimPart[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([jobId])
  @@index([status])
}

// Immutable audit trail for an issue — powers the tracking timeline. actorName is
// denormalized so history survives user renames/removal.
model IssueEvent {
  id         String         @id @default(cuid())
  issue      Issue          @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId    String
  type       IssueEventType
  fromStatus IssueStatus?
  toStatus   IssueStatus?
  note       String?
  actorName  String?
  createdAt  DateTime       @default(now())

  @@index([issueId])
}

// Spare-parts inventory — stock on hand + sell price + service (ช่าง) fee, used to
// quote out-of-warranty claims. Mirrors the "อุปกรณ์ Spare ใน Stock" sheet.
model SparePart {
  id             String   @id @default(cuid())
  name           String
  category       String?
  stockQty       Int      @default(0)
  sellPrice      Decimal?
  serviceFee1    Decimal? // ค่าบริการช่าง 1 คน/วัน
  serviceFee2    Decimal? // ค่าบริการช่าง 2 คน/วัน
  requiresOnsite Boolean  @default(false)
  imageUrl       String?
  remark         String?
  active         Boolean  @default(true)
  claimParts     ClaimPart[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Spare part(s) used on a claim/repair — links the claim to the inventory item.
// name/unitPrice are snapshots so history survives part rename/removal.
model ClaimPart {
  id            String     @id @default(cuid())
  issue         Issue      @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId       String
  sparePart     SparePart? @relation(fields: [sparePartId], references: [id], onDelete: SetNull)
  sparePartId   String?
  stockProductId String?   // อะไหล่จากคลังสินค้า (กลุ่มอะไหล่) ที่ตัดออก
  name          String
  qty           Int        @default(1)
  unitPrice     Decimal?
  stockDeducted Boolean    @default(false)
  createdAt     DateTime   @default(now())

  @@index([issueId])
}

// Per-unit QC: checklist + status + inspector, keyed to a BMS-unit SerialNumber.
model UnitQc {
  id        String   @id @default(cuid())
  serial    SerialNumber @relation(fields: [serialId], references: [id], onDelete: Cascade)
  serialId  String   @unique
  staff     User?    @relation("UnitQcStaff", fields: [staffId], references: [id])
  staffId   String?
  status    QcStatus @default(PENDING)
  checklist Json     @default("[]")
  keyId     String?  // Key ID / MAC Address ของเครื่อง (บันทึกตอน QC)
  licenseKey String? // License Key ของเครื่อง (บันทึกตอน QC)
  memoLicense Boolean @default(false) // ขอเปิด MEMO License แล้วหรือยัง (ติ๊กตอน QC)
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Step 2 — Serial recording: who did it + status (serials themselves are SerialNumber rows).
model SerialRecord {
  id        String       @id @default(cuid())
  job       Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId     String       @unique
  staff     User?        @relation("SerialStaff", fields: [staffId], references: [id])
  staffId   String?
  status    SerialStatus @default(PENDING)
  // Auto-computed when status = DONE: +3 business days (skip Sat/Sun).
  qcPlannedDate DateTime?
  remark    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model QcRecord {
  id        String   @id @default(cuid())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId     String   @unique
  staff     User?    @relation("QcStaff", fields: [staffId], references: [id])
  staffId   String?
  status    QcStatus @default(PENDING)
  checklist Json     @default("[]")
  remark    String?
}

model DeliveryRecord {
  id            String         @id @default(cuid())
  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId         String         @unique
  shippedDate   DateTime?
  arrivedDate   DateTime?
  method        String?
  vehicle       String?
  trackingNo    String?
  estimatedCost Decimal?
  actualCost    Decimal?
  status        DeliveryStatus @default(PENDING)
  remark        String?
  recordedById  String?
  updatedAt     DateTime?      @updatedAt
}

model InstallationRecord {
  id          String        @id @default(cuid())
  job         Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId       String        @unique
  installType InstallType   @default(REMOTE_ONSITE)
  remoteDate  DateTime?
  onsiteDate  DateTime?
  result      String?
  problem     String?
  solution    String?
  status      InstallStatus @default(PENDING)
  recordedById String?
  updatedAt   DateTime?     @updatedAt
}

model HandoverRecord {
  id                    String         @id @default(cuid())
  job                   Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId                 String         @unique
  checklistStatus       HandoverStatus @default(PENDING)
  checklistReceivedDate DateTime?
  handoverStatus        HandoverStatus @default(PENDING)
  handoverDate          DateTime?
  remark                String?
  recordedById          String?
  updatedAt             DateTime?      @updatedAt
}

model InvoiceRecord {
  id            String        @id @default(cuid())
  job           Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId         String        @unique
  status        InvoiceStatus @default(PENDING)
  invoiceDate   DateTime?
  // Warranty runs 1 year from the invoice open date; recomputed whenever invoiceDate changes.
  warrantyEndDate DateTime?
  invoiceNo     String?
  invoiceAmount Decimal?
  remark        String?
  recordedById  String?
  updatedAt     DateTime?     @updatedAt
}

model JobActivity {
  id                String         @id @default(cuid())
  job               Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId             String
  activityType      ActivityType
  activityDate      DateTime
  responsibleUser   User?          @relation(fields: [responsibleUserId], references: [id])
  responsibleUserId String?
  status            ActivityStatus @default(PENDING)
  remark            String?

  @@index([activityDate])
}

model Attachment {
  id           String   @id @default(cuid())
  refTable     String
  refId        String
  fileName     String
  fileType     String
  filePath     String
  fileSize     Int
  uploadedById String?
  uploadedAt   DateTime @default(now())

  @@index([refTable, refId])
}

model MasterOption {
  id        String   @id @default(cuid())
  category  String
  value     String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, value])
  @@index([category])
}

// Per-product-type QC checklist item (free text). Falls back to a default set
// when a product type has no rows configured.
model ProductChecklistItem {
  id          String   @id @default(cuid())
  productType String
  label       String
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productType, label])
  @@index([productType])
}

// A component (part) in a product type's bill of materials, e.g. "Tablet" ×1.
// needsSerial = collect a serial number for it in the QC form.
model ProductComponent {
  id          String   @id @default(cuid())
  productType String
  name        String
  quantity    Int      @default(1)
  needsSerial Boolean  @default(true)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productType, name])
  @@index([productType])
}

// BMS serial code per product type, e.g. "CIPD" → BMS-CIPD69-001. Used to
// auto-generate the next S/N BMS.
model ProductBmsCode {
  id          String   @id @default(cuid())
  productType String   @unique
  code        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Which serial types a product type collects (chosen from the SerialType set).
model ProductSerialSlot {
  id          String     @id @default(cuid())
  productType String
  serialType  SerialType
  sortOrder   Int        @default(0)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([productType, serialType])
  @@index([productType])
}

// ── Equipment stock (คลังสินค้า) ── serial-level finished-goods inventory:
// received into stock by Lot, then issued out to hospitals (jobs).
enum StockStatus {
  IN_STOCK
  ISSUED
  BORROWED // ถูกยืมออกไป — ยังเป็นของคลัง รอคืน
}

// Catalog of trackable stock items (finished goods / equipment).
model StockProduct {
  id          String     @id @default(cuid())
  group       String     // กลุ่มสินค้า: Smart Kiosk / Mini Kiosk / ชุดปิดสิทธิ / QR Code Payment / IPD Paperless / Kiosk เฉิงตู
  name        String     // รายการอุปกรณ์: ตู้ Kiosk, Smart Card, Tablet Redmi Pad Pro, ...
  unit        String     @default("เครื่อง")
  serialized  Boolean    @default(true) // track individual serials vs quantity-only
  sellPrice   Decimal?   // ราคาขาย (เช่น อะไหล่) — ใช้ทำใบเสนอราคา
  lowStockQty Int        @default(3)    // แจ้งเตือนใกล้หมด เมื่อคงเหลือ <= ค่านี้
  sortOrder   Int        @default(0)
  active      Boolean    @default(true)
  lots        StockLot[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([group, name])
}

// A receiving batch (Lot) of a product.
model StockLot {
  id           String       @id @default(cuid())
  product      StockProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  lotCode      String       // "1/68", "2/68", "Start Smart Lot.1/68", ...
  receivedQty  Int          @default(0)
  receivedDate DateTime?
  note         String?
  items        StockItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([productId])
}

// Individual unit (serial-level ledger row).
model StockItem {
  id            String      @id @default(cuid())
  lot           StockLot    @relation(fields: [lotId], references: [id], onDelete: Cascade)
  lotId         String
  seq           Int?        // ลำดับในเอกสาร
  serialBMS     String?     // BMS-KI68-049
  serialNo      String?     // manufacturer serial number
  color         String?     // สี (สำหรับตู้)
  status        StockStatus @default(IN_STOCK)
  receivedDate  DateTime?   // รับสินค้าเข้า
  issuedDate    DateTime?   // วันจำหน่ายสินค้าออก
  deliveredDate DateTime?   // วันจัดส่งถึงโรงพยาบาล
  // Issued-to: free-text hospital, plus optional links to existing system records.
  hospitalName  String?
  hospital      Hospital?   @relation(fields: [hospitalId], references: [id])
  hospitalId    String?
  job           Job?        @relation(fields: [jobId], references: [id])
  jobId         String?
  note          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  loans         Loan[]

  @@index([lotId])
  @@index([status])
  @@index([serialBMS])
  @@index([hospitalId])
}

enum LoanStatus {
  BORROWED
  RETURNED
}

// ทะเบียนยืม-คืน: one row per unit lent out of stock. The borrower's name and
// phone are required so an item is never handed over anonymously; while a loan
// is open its StockItem sits in BORROWED so the stock board shows it as unavailable.
model Loan {
  id            String     @id @default(cuid())
  item          StockItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId        String
  borrowerName  String     // ชื่อผู้ยืม (บังคับ)
  borrowerPhone String     // เบอร์โทร (บังคับ)
  borrowerOrg   String?    // หน่วยงาน/สังกัด
  purpose       String?    // วัตถุประสงค์การยืม
  borrowedAt    DateTime   @default(now())
  dueDate       DateTime   // กำหนดคืน (บังคับ) — เกินแล้วขึ้นแจ้งเตือน
  returnedAt    DateTime?
  returnNote    String?    // สภาพของตอนรับคืน
  status        LoanStatus @default(BORROWED)
  recordedBy    User?      @relation("LoanRecorder", fields: [recordedById], references: [id])
  recordedById  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([itemId])
  @@index([status])
  @@index([dueDate])
}
